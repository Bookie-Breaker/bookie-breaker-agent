# agent environment variables
PORT=8006
LOG_LEVEL=info
# agent_svc role owns the agent schema (infra-ops init-db);
# search_path must include public for the shared enum types
DATABASE_URL=postgres://agent_svc:localdev@localhost:5432/bookiebreaker?search_path=agent,public
REDIS_URL=redis://localhost:6379
LINES_SERVICE_URL=http://localhost:8001
STATISTICS_SERVICE_URL=http://localhost:8002
SIMULATION_ENGINE_URL=http://localhost:8003
PREDICTION_ENGINE_URL=http://localhost:8004
BOOKIE_EMULATOR_URL=http://localhost:8005
# Edge detection and auto-bet sizing (algorithms/edge-detection.md)
# DEVIG_METHOD=multiplicative  # multiplicative | additive | shin
# KELLY_MULTIPLIER=0.25
# MAX_BET_PCT=0.05
# MAX_TOTAL_EXPOSURE=0.15
# PIPELINE_CONCURRENCY=4
# OpenTelemetry (unset disables exporters; compose sets otel-collector:4317)
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
# OTEL_SERVICE_NAME=agent
# LLM analysis (ADR-011: provider switch is config-only)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LLM_PROVIDER=anthropic  # or ollama
# LLM_BASE_URL=  # Override for Ollama (http://localhost:11434) or custom endpoint
# LLM_MODEL=claude-opus-4-8  # quality tier (Ollama example: llama3.1:8b)
# LLM_MODEL_CHEAP=claude-haiku-4-5  # cheap tier: summaries + alert descriptions
# LLM_MAX_TOKENS=2048
# LLM_TIMEOUT_SECONDS=60
# ANALYSIS_CACHE_TTL_SECONDS=3600
# Scheduler, event re-runs, alerting
# SCHEDULE_MISFIRE_GRACE_SECONDS=300
# DAILY_SUMMARY_ENABLED=true
# DAILY_SUMMARY_CRON=0 12 * * *
# DAILY_SUMMARY_TIMEZONE=UTC
# EVENT_RERUNS_ENABLED=true
# RERUN_DEBOUNCE_SECONDS=120
# RERUN_COOLDOWN_SECONDS=600
# ALERT_LLM_DESCRIPTIONS=true
# ALERT_LLM_MAX_PER_RUN=10
# Live edges (Phase 7 Wave 2): trimmed in-game re-evaluation on is_live lines.updated frames
# LIVE_EDGES_ENABLED=false
# LIVE_DEBOUNCE_SECONDS=5.0
# LIVE_EDGE_TTL_SECONDS=120
# Player-prop edges (Phase 7 Wave 3): JSON list of leagues; [] disables the prop step
# PROP_EDGES_LEAGUES=["FIFA_WC","EPL","MLB"]
# SINGLE_SIDED_VIG_HAIRCUT=0.06  # p_true_est = implied / (1 + haircut) for YES/NO one-sided props
# Parlays (Phase 7 Wave 1; prop legs Wave 4). Scan + auto-bet default off; /parlays/evaluate always on
# PARLAY_SCAN_ENABLED=false
# PARLAY_SCAN_MIN_EDGE_PCT=0.6  # fraction of the league min EV an edge needs to enter the scan
# PARLAY_AUTO_BET=false
# PARLAY_SCAN_INCLUDE_PROPS=false  # admit PLAYER_PROP edges as scanner legs (max 2 per combo)
